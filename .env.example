# === CONFIGURACIÓN DE SECRETOS (PLANTILLA) ===
# Renombra este archivo a '.env' y completa los valores.
# IMPORTANTE: No compartas tu archivo '.env' real.

# --- Notificaciones: Telegram ---
# Crea un bot en @BotFather y obtén tu token.
# Usa @userinfobot para obtener tu CHAT_ID.
TELEGRAM_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# --- Notificaciones: Webhooks ---
# URL para Google Apps Script u otros servicios de integración.
WEBHOOK_URL=https://hooks.example.com/api/vision

# --- IA: Ollama (Local) ---
# Requiere tener Ollama instalado y corriendo (https://ollama.com).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava

# --- IA: HuggingFace (Cloud) ---
# Requiere un token de acceso de https://huggingface.co/settings/tokens.
HUGGINGFACE_API_KEY=hf_tu_token_aqui
HUGGINGFACE_MODEL=Salesforce/blip-vqa-base
